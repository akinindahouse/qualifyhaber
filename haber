function splitBrand(){
  const text = state.brandText || '';
  const hi = state.brandHighlight || '';
  if(hi && text.includes(hi)){
    const idx = text.indexOf(hi);
    return {pre:text.slice(0,idx), hi:hi, post:text.slice(idx+hi.length)};
  }
  return {pre:text, hi:'', post:''};
}

function updateWordmark(){
  const parts = splitBrand();
  $('wmPre').textContent = parts.pre;
  $('wmHi').textContent = parts.hi;
  $('wmPost').textContent = parts.post;
}

function render(){
  $('frameOverlay').style.background = state.gradStyle==='radial'
    ? 'radial-gradient(circle at 50% 50%, '+hexToRgba(state.c1,state.opacity/100)+', '+hexToRgba(state.c2,Math.min(1,state.opacity/100+0.25))+')'
    : 'linear-gradient('+state.angle+'deg, '+hexToRgba(state.c1,state.opacity/100)+', '+hexToRgba(state.c2,Math.min(1,state.opacity/100+0.25))+')';
  $('frameTag').textContent = state.tag;
  $('frameTitle').textContent = state.title || 'Başlığı buraya yaz';
  updateWordmark();
}
render();

/* ---------- canvas export ---------- */
const SAFE = { top:0.115, bottom:0.17, side:0.06, rightIcons:0.13 };
const exportCanvas = $('exportCanvas');
const ctx = exportCanvas.getContext('2d');
const CW = exportCanvas.width, CH = exportCanvas.height;

function drawCover(mediaEl, mw, mh, extraScale){
  if(!mw||!mh) return;
  const s = extraScale || 1;
  const scale = Math.max(CW/mw, CH/mh) * s;
  const dw = mw*scale, dh = mh*scale;
  const dx = (CW-dw)/2, dy = (CH-dh)/2;
  ctx.drawImage(mediaEl, dx, dy, dw, dh);
}

function angleCoords(angleDeg, w, h){
  const rad = (angleDeg-90) * Math.PI/180;
  const x = Math.cos(rad), y = Math.sin(rad);
  const cx=w/2, cy=h/2, len = Math.sqrt(w*w+h*h)/2;
  return {x1:cx-x*len, y1:cy-y*len, x2:cx+x*len, y2:cy+y*len};
}

function drawGradient(){
  let grad;
  const a1 = state.opacity/100, a2 = Math.min(1, state.opacity/100+0.25);
  if(state.gradStyle==='radial'){
    grad = ctx.createRadialGradient(CW/2,CH/2,0,CW/2,CH/2,Math.max(CW,CH)*0.75);
  } else {
    const c = angleCoords(state.angle, CW, CH);
    grad = ctx.createLinearGradient(c.x1,c.y1,c.x2,c.y2);
  }
  grad.addColorStop(0, hexToRgba(state.c1,a1));
  grad.addColorStop(1, hexToRgba(state.c2,a2));
  ctx.fillStyle = grad;
  ctx.fillRect(0,0,CW,CH);
}

function wrapLines(text, font, maxWidth){
  ctx.font = font;
  const words = text.split(/\s+/).filter(Boolean);
  const lines = [];
  let cur = '';
  for(const w of words){
    const test = cur ? cur+' '+w : w;
    if(ctx.measureText(test).width > maxWidth && cur){
      lines.push(cur); cur = w;
    } else cur = test;
  }
  if(cur) lines.push(cur);
  return lines;
}

function drawBrand(){
  if(!state.brandVisible) return;
  const topY = CH*SAFE.top;
  const leftX = CW*SAFE.side;
  if(state.brandMode==='logo' && state.logoImg){
    const maxH = 96, ratio = state.logoImg.naturalWidth/state.logoImg.naturalHeight;
    const h = maxH, w = h*ratio;
    ctx.drawImage(state.logoImg, leftX, topY, w, h);
  } else {
    const parts = splitBrand();
    ctx.textBaseline = 'top';
    ctx.font = "700 56px 'Archivo Black', sans-serif";
    ctx.shadowColor = 'rgba(0,0,0,.55)'; ctx.shadowBlur = 18; ctx.shadowOffsetY = 4;
    let x = leftX;
    if(parts.pre){
      ctx.fillStyle = '#FFFFFF';
      ctx.fillText(parts.pre, x, topY);
      x += ctx.measureText(parts.pre).width;
    }
    if(parts.hi){
      ctx.fillStyle = '#FF3B30';
      ctx.fillText(parts.hi, x, topY);
      x += ctx.measureText(parts.hi).width;
    }
    if(parts.post){
      ctx.fillStyle = '#FFFFFF';
      ctx.fillText(parts.post, x, topY);
    }
    ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
  }
}

function drawTextBlock(){
  const rightLimit = CW - CW*(SAFE.side + SAFE.rightIcons);
  const leftX = CW*SAFE.side;
  const maxWidth = rightLimit - leftX;
  const bottomLimit = CH - CH*SAFE.bottom;

  ctx.textBaseline = 'alphabetic';
  const titleFont = "900 66px 'Archivo Black', sans-serif";
  const lines = wrapLines(state.title || ' ', titleFont, maxWidth).slice(0,4);
  const lineHeight = 76;
  const tagH = 58;
  const gap = 22;
  const totalH = tagH + gap + lines.length*lineHeight;
  let cursorY = bottomLimit - totalH;

  ctx.font = "700 30px 'Space Mono', monospace";
  const tagText = (state.tag||'GÜNDEM').toUpperCase();
  const tagPadX = 26;
  const tagW = ctx.measureText(tagText).width + tagPadX*2;
  ctx.fillStyle = '#FFB020';
  roundRect(leftX, cursorY, tagW, tagH-12, 6);
  ctx.fill();
  ctx.fillStyle = '#0A0C0F';
  ctx.textBaseline = 'middle';
  ctx.fillText(tagText, leftX+tagPadX, cursorY + (tagH-12)/2 + 1);

  let ty = cursorY + tagH + gap + lineHeight*0.78;
  ctx.font = titleFont;
  ctx.fillStyle = '#FFFFFF';
  ctx.shadowColor = 'rgba(0,0,0,.6)'; ctx.shadowBlur = 22; ctx.shadowOffsetY = 4;
  ctx.textBaseline = 'alphabetic';
  for(const line of lines){
    ctx.fillText(line, leftX, ty);
    ty += lineHeight;
  }
  ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
}

function roundRect(x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}

function drawFrame(elapsedMs){
  if(state.sourceMode==='video' && state.hasVideo && frameVideo.readyState >= 2){
    drawCover(frameVideo, frameVideo.videoWidth, frameVideo.videoHeight, 1);
  } else if(state.sourceMode==='photo' && state.hasPhoto && state.photoImg){
    let scale = 1;
    if(state.kenBurns && elapsedMs!=null){
      const durMs = state.photoDurationSec*1000;
      const r = Math.min(1, elapsedMs/durMs);
      scale = 1 + r*0.08;
    }
    drawCover(state.photoImg, state.photoImg.naturalWidth, state.photoImg.naturalHeight, scale);
  } else {
    ctx.fillStyle = '#050608';
    ctx.fillRect(0,0,CW,CH);
  }
  drawGradient();
  drawBrand();
  drawTextBlock();
}

function fmtTime(s){
  const m = Math.floor(s/60).toString().padStart(2,'0');
  const sec = Math.floor(s%60).toString().padStart(2,'0');
  return m+':'+sec;
}

function downloadBlob(blob, filename){
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  setTimeout(()=>URL.revokeObjectURL(url), 4000);
}

let ffmpegInstance = null;
let ffmpegLoaded = false;
async function getFFmpeg(onStage){
  if(ffmpegInstance) return ffmpegInstance;
  const { createFFmpeg } = FFmpeg;
  ffmpegInstance = createFFmpeg({
    log:false,
    corePath:'https://unpkg.com/@ffmpeg/core@0.11.0/dist/ffmpeg-core.js'
  });
  if(onStage) onStage('Dönüştürme motoru hazırlanıyor (ilk seferde sürebilir)…');
  await ffmpegInstance.load();
  ffmpegLoaded = true;
  return ffmpegInstance;
}

async function convertToMp4(webmBlob, w, h, onStage, onProgress){
  const { fetchFile } = FFmpeg;
  const ff = await getFFmpeg(onStage);
  if(onStage) onStage('MP4\u2019e dönüştürülüyor…');
  ff.setProgress(({ratio})=>{
    if(onProgress) onProgress(Math.round(Math.min(1, Math.max(0, ratio||0))*100));
  });
  ff.FS('writeFile', 'input.webm', await fetchFile(webmBlob));
  await ff.run(
    '-i','input.webm',
    '-vf','scale='+w+':'+h,
    '-c:v','libx264','-preset','veryfast','-crf','20','-pix_fmt','yuv420p',
    '-c:a','aac','-b:a','128k',
    '-movflags','+faststart',
    'output.mp4'
  );
  const data = ff.FS('readFile', 'output.mp4');
  try{ ff.FS('unlink','input.webm'); ff.FS('unlink','output.mp4'); }catch(e){}
  return new Blob([data.buffer], {type:'video/mp4'});
}

$('exportPngBtn').addEventListener('click', async ()=>{
  await document.fonts.ready;
  drawFrame(0);
  exportCanvas.toBlob(blob=>{
    downloadBlob(blob, 'qualifyhaber-kapak.png');
  }, 'image/png');
});

let recTimer = null, recStart = 0;
function setRecordingUI(on){
  state.recording = on;
  $('recDot').classList.toggle('live', on);
  if(on){
    $('recLabel').textContent = 'KAYDEDİLİYOR';
    $('exportVideoBtn').textContent = 'Kaydediliyor…';
  } else {
    $('recLabel').textContent = 'ÖNİZLEME';
    $('exportVideoBtn').textContent = 'Reels videosu indir (MP4)';
  }
  updateExportButtonState();
  if(on){
    recStart = performance.now();
    recTimer = setInterval(()=>{
      $('timecode').textContent = fmtTime((performance.now()-recStart)/1000);
    }, 200);
  } else {
    clearInterval(recTimer);
    $('timecode').textContent = '00:00';
  }
}

function setStage(label){
  $('recLabel').textContent = label;
  $('exportVideoBtn').textContent = label;
}
function setStageProgress(pct){
  $('timecode').textContent = pct+'%';
}

$('exportVideoBtn').addEventListener('click', async ()=>{
  if(state.recording || !exportReady()) return;
  await document.fonts.ready;

  const stream = exportCanvas.captureStream(30);
  if(state.sourceMode==='video'){
    try{
      const vStream = frameVideo.captureStream ? frameVideo.captureStream() : (frameVideo.mozCaptureStream ? frameVideo.mozCaptureStream() : null);
      if(vStream){ vStream.getAudioTracks().forEach(t=>stream.addTrack(t)); }
    }catch(err){}
  }

  let nativeMp4 = false;
  try{ nativeMp4 = MediaRecorder.isTypeSupported('video/mp4'); }catch(e){}

  const mimeType = nativeMp4 ? 'video/mp4' : (
    MediaRecorder.isTypeSupported('video/webm;codecs=vp9,opus') ? 'video/webm;codecs=vp9,opus' :
    (MediaRecorder.isTypeSupported('video/webm;codecs=vp8,opus') ? 'video/webm;codecs=vp8,opus' : 'video/webm')
  );

  let recorder;
  try{
    recorder = new MediaRecorder(stream, {mimeType, videoBitsPerSecond:8000000});
  }catch(err){
    alert('Tarayıcın video kaydını desteklemiyor. Güncel bir Chrome ile dene.');
    return;
  }
  const chunks = [];
  recorder.ondataavailable = e=>{ if(e.data && e.data.size) chunks.push(e.data); };
  recorder.onstop = async ()=>{
    const rawBlob = new Blob(chunks, {type: nativeMp4 ? 'video/mp4' : 'video/webm'});

    if(nativeMp4){
      downloadBlob(rawBlob, 'qualifyhaber-reels.mp4');
      setRecordingUI(false);
      return;
    }

    try{
      const [w,h] = state.exportRes.split('x').map(Number);
      const mp4Blob = await convertToMp4(rawBlob, w, h, setStage, setStageProgress);
      downloadBlob(mp4Blob, 'qualifyhaber-reels.mp4');
    }catch(err){
      console.error(err);
      alert('MP4\u2019e dönüştürme başarısız oldu, WEBM olarak indirildi. Telefonda CapCut veya VLC ile mp4\u2019e çevirebilirsin.');
      downloadBlob(rawBlob, 'qualifyhaber-reels.webm');
    } finally {
      setRecordingUI(false);
    }
  };

  let raf, recStartTs;
  function loop(){
    const elapsed = performance.now() - recStartTs;
    drawFrame(elapsed);
    raf = requestAnimationFrame(loop);
  }

  setRecordingUI(true);

  let durMs;
  if(state.sourceMode==='video'){
    frameVideo.currentTime = 0;
    try{ await frameVideo.play(); }catch(err){}
    durMs = (frameVideo.duration && isFinite(frameVideo.duration)) ? frameVideo.duration*1000 : 8000;
  } else {
    durMs = state.photoDurationSec*1000;
  }

  recStartTs = performance.now();
  recorder.start();
  loop();

  setTimeout(()=>{
    cancelAnimationFrame(raf);
    if(recorder.state !== 'inactive') recorder.stop();
  }, durMs);
});
</script>
