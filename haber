preview-info .dash.yellow{border-color:#ffad00}.preview-info b{color:#ffad00}.preview-info h3{margin:0 0 3px;color:#d9dde3;font-size:15px}.preview-info small{color:#8b929d}.footer-note{position:fixed;left:20px;bottom:6px;color:#6e7681;font-size:11px}
