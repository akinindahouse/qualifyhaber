/* ---------- canvas export ---------- */
const SAFE_PROFILES = {
  reels:{ top:0.115, bottom:0.17, side:0.06, rightIcons:0.13 },
  post:{ top:0.06, bottom:0.08, side:0.06, rightIcons:0 }
};
let SAFE = SAFE_PROFILES.reels;
const exportCanvas = $('exportCanvas');
const ctx = exportCanvas.getContext('2d');
let CW = exportCanvas.width, CH = exportCanvas.height;

function drawCover(mediaEl, mw, mh, extraScale){
  if(!mw||!mh) return;
  const s = extraScale || 1;
  const scale = Math.max(CW/mw, CH/mh) * s;
  const dw = mw*scale, dh = mh*scale;
  const dx = (CW-dw)/2, dy = (CH-dh)/2;
  ctx.drawImage(mediaEl, dx, dy, dw, dh);
}

function angleCoords(angleDeg, w, h){
  const rad = (angleDeg-90) * Math.PI/180;
  const x = Math.cos(rad), y = Math.sin(rad);
  const cx=w/2, cy=h/2, len = Math.sqrt(w*w+h*h)/2;
  return {x1:cx-x*len, y1:cy-y*len, x2:cx+x*len, y2:cy+y*len};
}

function drawGradient(){
  const baseA = state.opacity/100;
  const strongA = Math.min(1, baseA + 0.18);
  const midA = Math.max(0, baseA * 0.55);

  if(state.gradientArea === 'text'){
    const gx = 0;
    const gy = CH*0.44;
    const gw = CW;
    const gh = CH*0.56;
    let grad;
    if(state.gradStyle==='radial'){
      grad = ctx.createRadialGradient(CW/2, gy+gh*0.92, 0, CW/2, gy+gh*0.92, Math.max(gw,gh)*0.72);
      grad.addColorStop(0, hexToRgba(state.c1, strongA));
      grad.addColorStop(0.48, hexToRgba(state.c2, midA));
      grad.addColorStop(0.78, 'rgba(0,0,0,0)');
      grad.addColorStop(1, 'rgba(0,0,0,0)');
    } else {
      grad = ctx.createLinearGradient(0, gy+gh, 0, gy);
      grad.addColorStop(0, hexToRgba(state.c2, strongA));
      grad.addColorStop(0.45, hexToRgba(state.c1, baseA));
      grad.addColorStop(0.68, hexToRgba(state.c1, midA));
      grad.addColorStop(1, 'rgba(0,0,0,0)');
    }
    ctx.fillStyle = grad;
    ctx.fillRect(gx,gy,gw,gh);
    return;
  }

  let grad;
  const a1 = baseA, a2 = Math.min(1, baseA+0.25);
  if(state.gradStyle==='radial'){
    grad = ctx.createRadialGradient(CW/2,CH/2,0,CW/2,CH/2,Math.max(CW,CH)*0.75);
  } else {
    const c = angleCoords(state.angle, CW, CH);
    grad = ctx.createLinearGradient(c.x1,c.y1,c.x2,c.y2);
  }
  grad.addColorStop(0, hexToRgba(state.c1,a1));
  grad.addColorStop(1, hexToRgba(state.c2,a2));
  ctx.fillStyle = grad;
  ctx.fillRect(0,0,CW,CH);
}

function wrapLines(text, font, maxWidth){
  ctx.font = font;
  const words = text.split(/\s+/).filter(Boolean);
  const lines = [];
  let cur = '';
  for(const w of words){
    const test = cur ? cur+' '+w : w;
    if(ctx.measureText(test).width > maxWidth && cur){
      lines.push(cur); cur = w;
    } else cur = test;
  }
  if(cur) lines.push(cur);
  return lines;
}

function drawBrand(){
  if(!state.brandVisible) return;
  const topY = CH*SAFE.top;
  const leftX = CW*SAFE.side;
  if(state.brandMode==='logo' && state.logoImg){
    const maxH = 96, ratio = state.logoImg.naturalWidth/state.logoImg.naturalHeight;
    const h = maxH, w = h*ratio;
    ctx.drawImage(state.logoImg, leftX, topY, w, h);
  } else {
    const parts = splitBrand();
    ctx.textBaseline = 'top';
    ctx.font = "700 56px 'Archivo Black', sans-serif";
    ctx.shadowColor = 'rgba(0,0,0,.55)'; ctx.shadowBlur = 18; ctx.shadowOffsetY = 4;
    let x = leftX;
    if(parts.pre){
      ctx.fillStyle = '#FFFFFF';
      ctx.fillText(parts.pre, x, topY);
      x += ctx.measureText(parts.pre).width;
    }
    if(parts.hi){
      ctx.fillStyle = '#FF3B30';
      ctx.fillText(parts.hi, x, topY);
      x += ctx.measureText(parts.hi).width;
    }
    if(parts.post){
      ctx.fillStyle = '#FFFFFF';
      ctx.fillText(parts.post, x, topY);
    }
    ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
  }
}

function fitTitleLines(text, maxWidth, maxHeight, maxFont, minFont, lineHeightRatio){
  let fontSize = maxFont;
  let lines = [], lineHeight = 0;
  while(fontSize >= minFont){
    const font = "900 "+fontSize+"px 'Archivo Black', sans-serif";
    lines = wrapLines(text || ' ', font, maxWidth);
    lineHeight = Math.round(fontSize * lineHeightRatio);
    const totalH = lines.length * lineHeight;
    if(totalH <= maxHeight) return {fontSize, lines, lineHeight};
    fontSize -= 2;
  }
  // Pathological fallback (shouldn't happen within the 110-char limit):
  // keep the smallest size and fit as many lines as the space allows, no mid-sentence cut without marking it.
  fontSize = minFont;
  const font = "900 "+fontSize+"px 'Archivo Black', sans-serif";
  lines = wrapLines(text || ' ', font, maxWidth);
  lineHeight = Math.round(fontSize * lineHeightRatio);
  const maxLines = Math.max(1, Math.floor(maxHeight / lineHeight));
  if(lines.length > maxLines){
    lines = lines.slice(0, maxLines);
    const last = lines[lines.length-1];
    lines[lines.length-1] = last.replace(/\s+\S*$/, '') + '…';
  }
  return {fontSize, lines, lineHeight};
}

function getHintReserveH(){
  return state.slideHintVisible ? CH*0.065 : 0;
}

function drawTextBlock(){
  const rightLimit = CW - CW*(SAFE.side + SAFE.rightIcons);
  const leftX = CW*SAFE.side;
  const maxWidth = rightLimit - leftX;
  const bottomLimit = (CH - CH*SAFE.bottom) - getHintReserveH();
  const topLimit = CH * 0.30;

  ctx.textBaseline = 'alphabetic';
  const tagH = 58;
  const gap = 22;
  const availableForLines = (bottomLimit - topLimit) - tagH - gap;
  const {fontSize, lines, lineHeight} = fitTitleLines(state.title, maxWidth, availableForLines, state.titleMaxFont||66, 32, 1.15);
  const titleFont = "900 "+fontSize+"px 'Archivo Black', sans-serif";

  const totalH = tagH + gap + lines.length*lineHeight;
  let cursorY = bottomLimit - totalH;

  ctx.font = "700 30px 'Space Mono', monospace";
  const tagText = (state.tag||'GÜNDEM').toUpperCase();
  const tagPadX = 26;
  const tagW = ctx.measureText(tagText).width + tagPadX*2;
  ctx.fillStyle = '#FFB020';
  roundRect(leftX, cursorY, tagW, tagH-12, 6);
  ctx.fill();
  ctx.fillStyle = '#0A0C0F';
  ctx.textBaseline = 'middle';
  ctx.fillText(tagText, leftX+tagPadX, cursorY + (tagH-12)/2 + 1);

  let ty = cursorY + tagH + gap + lineHeight*0.78;
  ctx.font = titleFont;
  ctx.fillStyle = state.titleColor || '#FFFFFF';
  ctx.shadowColor = 'rgba(0,0,0,.6)'; ctx.shadowBlur = 22; ctx.shadowOffsetY = 4;
  ctx.textBaseline = 'alphabetic';
  for(const line of lines){
    ctx.fillText(line, leftX, ty);
    ty += lineHeight;
  }
  ctx.shadowBlur = 0; ctx.shadowOffsetY = 0;
}

function roundRect(x,y,w,h,r){
  ctx.beginPath();
  ctx.moveTo(x+r,y);
  ctx.arcTo(x+w,y,x+w,y+h,r);
  ctx.arcTo(x+w,y+h,x,y+h,r);
  ctx.arcTo(x,y+h,x,y,r);
  ctx.arcTo(x,y,x+w,y,r);
  ctx.closePath();
}

function drawSlideHint(){
  if(!state.slideHintVisible) return;
  const text = state.slideHintText || 'Yana Kaydır';
  ctx.save();
  const hintColor = state.slideHintColor || '#FFFFFF';
  ctx.font = "700 28px 'Space Mono', monospace";
  ctx.textBaseline = 'middle';
  ctx.textAlign = 'center';
  ctx.fillStyle = hintColor;
  ctx.shadowColor = 'rgba(0,0,0,.7)'; ctx.shadowBlur = 18; ctx.shadowOffsetY = 3;
  const y = (CH - CH*SAFE.bottom) - getHintReserveH()/2;
  const textW = ctx.measureText(text).width;
  const groupW = textW + 44;
  const startX = (CW-groupW)/2;
  ctx.fillText(text, startX + textW/2, y);
  ctx.beginPath();
  const ax = startX + textW + 22;
  ctx.moveTo(ax-10, y); ctx.lineTo(ax+10, y);
  ctx.moveTo(ax+3, y-8); ctx.lineTo(ax+11, y); ctx.lineTo(ax+3, y+8);
  ctx.strokeStyle = hintColor; ctx.lineWidth = 4; ctx.lineCap = 'round'; ctx.lineJoin = 'round'; ctx.stroke();
  ctx.restore();
}

function drawFrame(elapsedMs){
  if(state.sourceMode==='video' && state.hasVideo && frameVideo.readyState >= 2){
    drawCover(frameVideo, frameVideo.videoWidth, frameVideo.videoHeight, 1);
  } else if(state.sourceMode==='photo' && state.hasPhoto && state.photoImg){
    let scale = 1;
    if(state.kenBurns && elapsedMs!=null){
      const durMs = state.photoDurationSec*1000;
      const r = Math.min(1, elapsedMs/durMs);
      scale = 1 + r*0.08;
    }
    drawCover(state.photoImg, state.photoImg.naturalWidth, state.photoImg.naturalHeight, scale);
  } else {
    ctx.fillStyle = '#050608';
    ctx.fillRect(0,0,CW,CH);
  }
  drawGradient();
  drawBrand();
  drawTextBlock();
  drawSlideHint();
}

function fmtTime(s){
  const m = Math.floor(s/60).toString().padStart(2,'0');
  const sec = Math.floor(s%60).toString().padStart(2,'0');
  return m+':'+sec;
}

function downloadBlob(blob, filename){
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url; a.download = filename; a.click();
  setTimeout(()=>URL.revokeObjectURL(url), 4000);
}

let ffmpegInstance = null;
let ffmpegLoaded = false;
async function getFFmpeg(onStage){
  if(ffmpegInstance) return ffmpegInstance;
  const { createFFmpeg } = FFmpeg;
  ffmpegInstance = createFFmpeg({
    log:false,
    corePath:'https://unpkg.com/@ffmpeg/core@0.11.0/dist/ffmpeg-core.js'
  });
  if(onStage) onStage('Dönüştürme motoru hazırlanıyor (ilk seferde sürebilir)…');
  await ffmpegInstance.load();
  ffmpegLoaded = true;
  return ffmpegInstance;
}

async function convertToMp4(webmBlob, w, h, onStage, onProgress){
  const { fetchFile } = FFmpeg;
  const ff = await getFFmpeg(onStage);
  if(onStage) onStage('MP4\u2019e dönüştürülüyor…');
  ff.setProgress(({ratio})=>{
    if(onProgress) onProgress(Math.round(Math.min(1, Math.max(0, ratio||0))*100));
  });
  ff.FS('writeFile', 'input.webm', await fetchFile(webmBlob));
  await ff.run(
    '-i','input.webm',
    '-vf','scale='+w+':'+h,
    '-c:v','libx264','-preset','veryfast','-crf','20','-pix_fmt','yuv420p',
    '-c:a','aac','-b:a','128k',
    '-movflags','+faststart',
    'output.mp4'
  );
  const data = ff.FS('readFile', 'output.mp4');
  try{ ff.FS('unlink','input.webm'); ff.FS('unlink','output.mp4'); }catch(e){}
  return new Blob([data.buffer], {type:'video/mp4'});
}

