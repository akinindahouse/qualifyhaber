<body>

<div class="topbar">
  <div class="brand">
    <div class="brand-mark">QH</div>
    <div class="brand-text">
      <h1>QualifyHaber</h1>
      <p>Sosyal İçerik Stüdyosu</p>
    </div>
  </div>
  <div class="topbar-tag" id="topbarFormatTag">9:16 · <b>Instagram Safe Zone</b> uyumlu</div>
</div>

<div class="workspace">

  <aside class="controls">

    <div class="section">
      <div class="section-head"><div class="section-num">1</div><h2>Boyut Seçimi</h2></div>
      <div class="toggle-row">
        <button class="active" id="formatReelsBtn">Reels 9:16</button>
        <button id="formatPostBtn">Post 4:5</button>
      </div>
      <p class="hint" id="formatHint">Reels formatında sağ ikon kolonu ve alt Instagram arayüz güvenli alanı dikkate alınır.</p>
    </div>

    <div class="section">
      <div class="section-head"><div class="section-num">2</div><h2>Medya Yükleme</h2></div>

      <div class="toggle-row">
        <button class="active" id="sourceModeVideo">Video</button>
        <button id="sourceModePhoto">Fotoğraf</button>
      </div>

      <div id="videoSourceFields">
        <div class="field">
          <label>Arka plan videosu</label>
