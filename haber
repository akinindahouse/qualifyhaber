<script src="https://unpkg.com/@ffmpeg/ffmpeg@0.11.6/dist/ffmpeg.min.js"></script>
<script>
const PRESETS = [
  {name:'Son Dakika', c1:'#FF2D2D', c2:'#1A0000', angle:160, style:'linear'},
  {name:'Gece Bülteni', c1:'#5A3CFF', c2:'#0A0A1A', angle:160, style:'linear'},
  {name:'Ekonomi', c1:'#FFB020', c2:'#1A1200', angle:160, style:'linear'},
  {name:'Spor', c1:'#1FD15A', c2:'#001A08', angle:160, style:'linear'},
  {name:'Sade Kontrast', c1:'#000000', c2:'#000000', angle:180, style:'radial'}
];

const DEFAULT_LOGO_URL = "data:image/png;base64,";

const state = {
  format:'reels',
  sourceMode:'video',
  hasVideo:false,
  videoFile:null,
  hasPhoto:false,
  photoFile:null,
  photoImg:null,
  photoDurationSec:6,
  kenBurns:true,
  brandVisible:true,
  brandMode:'text',
  brandText:'QualifyHaber',
  brandHighlight:'Haber',
  logoImg:null,
  logoIsDefault:true,
  tag:'GÜNDEM',
  title:'Başlığı buraya yaz, otomatik satır kırılır',
  titleColor:'#FFFFFF',
  titleMaxFont:66,
  c1:'#FF2D2D', c2:'#1A0000',
  gradStyle:'linear', angle:160, opacity:55, gradientArea:'text',
  safezone:true,
  slideHintVisible:false,
  slideHintText:'Yana Kaydır',
  slideHintColor:'#FFFFFF',
  recording:false,
  exportRes:'1080x1920'
};

const $ = id => document.getElementById(id);

const FORMAT_CONFIG = {
  reels:{
    label:'Reels 9:16', aspect:'9/16', previewWidth:'360px', defaultRes:'1080x1920',
    resolutions:[['1080x1920','1080×1920 — önerilen Reels standardı'], ['720x1280','720×1280 — daha hızlı, daha küçük dosya']],
    hint:'Reels formatında sağ ikon kolonu ve alt Instagram arayüz güvenli alanı dikkate alınır.',
    caption:'Çerçeve, gerçek Reels oynatıcısının üst profil alanını, alt başlık/buton şeridini ve sağdaki beğeni-yorum ikon kolonunu temsil eder. Metinleri bu kılavuzların dışında tutarsan Instagram arayüzü hiçbir şeyi kapatmaz.',
    filenamePrefix:'qualifyhaber-reels'
  },
  post:{
    label:'Post 4:5', aspect:'4/5', previewWidth:'430px', defaultRes:'1080x1350',
    resolutions:[['1080x1350','1080×1350 — önerilen Instagram 4:5 post'], ['800x1000','800×1000 — daha hızlı, daha küçük dosya']],
    hint:'Post formatında üst/alt boşluk ve yan kenar payları dikkate alınır; sağ Reels ikon kolonu kullanılmaz.',
    caption:'Çerçeve, Instagram 4:5 post görünümünü temsil eder. Başlık ve marka öğeleri üst/alt kenar boşluklarının dışında kalacak şekilde güvenli alanda konumlanır.',
    filenamePrefix:'qualifyhaber-post'
  }
};

const videoInput = $('videoInput');
const frameVideo = $('frameVideo');
const frameImage = $('frameImage');
const photoInput = $('photoInput');
const emptyFrame = $('emptyFrame');
const clearVideoWrap = $('clearVideoWrap');
const clearPhotoWrap = $('clearPhotoWrap');

function setCanvasSizeFromExportRes(){
  const [w,h] = state.exportRes.split('x').map(Number);
  exportCanvas.width = w;
  exportCanvas.height = h;
  CW = w;
  CH = h;
}

function refreshExportResOptions(){
  const config = FORMAT_CONFIG[state.format];
  const select = $('exportRes');
  select.innerHTML = '';
  config.resolutions.forEach(([value,label])=>{
    const opt = document.createElement('option');
    opt.value = value;
    opt.textContent = label;
    select.appendChild(opt);
  });
  state.exportRes = config.defaultRes;
  select.value = state.exportRes;
  setCanvasSizeFromExportRes();
}

function updateFormatUI(){
  const isReels = state.format === 'reels';
  const config = FORMAT_CONFIG[state.format];
  $('formatReelsBtn').classList.toggle('active', isReels);
  $('formatPostBtn').classList.toggle('active', !isReels);
  $('formatHint').textContent = config.hint;
  $('stageCaption').textContent = config.caption;
  $('topbarFormatTag').innerHTML = (isReels ? '9:16' : '4:5') + ' · <b>Instagram Safe Zone</b> uyumlu';
  document.documentElement.style.setProperty('--frame-aspect', config.aspect);
  document.documentElement.style.setProperty('--frame-w', config.previewWidth);
  SAFE = SAFE_PROFILES[state.format];
  $('frameBrand').style.right = isReels ? '18%' : '6%';
  $('frameLowerGroup').style.right = isReels ? '18%' : '6%';
  document.querySelector('.sz-band.top').style.height = (SAFE.top*100)+'%';
  document.querySelector('.sz-band.bottom').style.height = (SAFE.bottom*100)+'%';
  const sideZone = document.querySelector('.sz-side');
  sideZone.style.display = isReels ? 'block' : 'none';
  sideZone.style.top = (SAFE.top*100)+'%';
  sideZone.style.bottom = (SAFE.bottom*100)+'%';
  sideZone.style.width = (SAFE.rightIcons*100)+'%';
  document.querySelector('.sz-band.top .sz-label').textContent = isReels ? 'üst güvenli alan' : 'üst kenar payı';
  document.querySelector('.sz-band.bottom .sz-label').textContent = isReels ? 'alt güvenli alan · IG arayüzü' : 'alt kenar payı';
  updateSlideHintSafePosition();
  updatePreviewTitleSize();
}

function setFormat(format){
  if(state.recording || state.format === format) return;
  state.format = format;
  refreshExportResOptions();
  updateFormatUI();
  render();
}

$('formatReelsBtn').addEventListener('click', ()=>setFormat('reels'));
$('formatPostBtn').addEventListener('click', ()=>setFormat('post'));

function exportReady(){
  return (state.sourceMode==='video' && state.hasVideo) || (state.sourceMode==='photo' && state.hasPhoto);
}

function updateExportButtonState(){
  $('exportVideoBtn').disabled = state.recording || !exportReady();
  if(!state.recording){
    $('exportVideoBtn').textContent = state.format==='reels' ? 'Reels videosu indir (MP4)' : 'Post videosu indir (MP4)';
  }
}

function updateSourceUI(){
  const v = state.sourceMode==='video';
  $('sourceModeVideo').classList.toggle('active', v);
  $('sourceModePhoto').classList.toggle('active', !v);
  $('videoSourceFields').style.display = v ? 'block' : 'none';
  $('photoSourceFields').style.display = v ? 'none' : 'block';
  frameVideo.style.display = (v && state.hasVideo) ? 'block' : 'none';
  frameImage.style.display = (!v && state.hasPhoto) ? 'block' : 'none';
  emptyFrame.style.display = ((v && !state.hasVideo) || (!v && !state.hasPhoto)) ? 'flex' : 'none';
  if(v && state.hasVideo){ frameVideo.play().catch(()=>{}); }
  if(!v){ frameVideo.pause(); }
  updateExportButtonState();
}

$('sourceModeVideo').addEventListener('click', ()=>{ state.sourceMode='video'; updateSourceUI(); });
$('sourceModePhoto').addEventListener('click', ()=>{ state.sourceMode='photo'; updateSourceUI(); });

function hexToRgba(hex, a){
  const h = hex.replace('#','');
  const r = parseInt(h.substring(0,2),16), g = parseInt(h.substring(2,4),16), b = parseInt(h.substring(4,6),16);
  return 'rgba('+r+','+g+','+b+','+a+')';
}

function buildPresetSwatches(){
  const wrap = $('presetSwatches');
  wrap.innerHTML='';
  PRESETS.forEach((p,i)=>{
    const el = document.createElement('div');
    el.className='swatch'+(i===0?' active':'');
    el.style.background = p.style==='radial'
      ? 'radial-gradient(circle at 50% 50%,'+p.c1+','+p.c2+')'
      : 'linear-gradient('+p.angle+'deg,'+p.c1+','+p.c2+')';
    el.title = p.name;
    el.addEventListener('click', ()=>{
      document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('active'));
      el.classList.add('active');
      state.c1=p.c1; state.c2=p.c2; state.gradStyle=p.style; state.angle=p.angle;
      $('color1').value=p.c1; $('color2').value=p.c2; $('gradStyle').value=p.style; $('angle').value=p.angle;
      $('angleOut').textContent=p.angle+'°';
      render();
    });
    wrap.appendChild(el);
  });
}
buildPresetSwatches();

function deselectSwatches(){ document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('active')); }

videoInput.addEventListener('change', e=>{
  const f = e.target.files[0];
  if(!f) return;
  const url = URL.createObjectURL(f);
  frameVideo.src = url;
  frameVideo.play().catch(()=>{});
  state.hasVideo = true;
  state.videoFile = f;
  $('videoFileName').textContent = f.name.length>18 ? f.name.slice(0,16)+'…' : f.name;
  clearVideoWrap.style.display='block';
  updateSourceUI();
});

$('clearVideoBtn').addEventListener('click', ()=>{
  frameVideo.pause();
  frameVideo.removeAttribute('src');
  frameVideo.load();
  state.hasVideo=false; state.videoFile=null;
  $('videoFileName').textContent='';
  clearVideoWrap.style.display='none';
  videoInput.value='';
  updateSourceUI();
});

function updatePhotoAnim(){
  frameImage.classList.toggle('kenburns-anim', state.kenBurns && state.hasPhoto);
}

function setPhotoStatus(msg, isError){
  const el = $('photoUrlStatus');
  el.textContent = msg;
  el.style.color = isError ? '#FF6B60' : '';
}
const PHOTO_STATUS_DEFAULT = "Linki kutuya yapıştırıp Yükle'ye bas — ya da doğrudan Ctrl+V ile görseli/linki kutuya yapıştırabilirsin. jpg, png ve webp destekli. Bazı sitelerin görselleri korumalı olduğu için her linkte çalışmayabilir; olmazsa görseli indirip dosya olarak yükle.";

function applyPhotoImage(img, label){
  state.photoImg = img;
  state.hasPhoto = true;
  frameImage.src = img.src;
  $('photoFileName').textContent = label;
  clearPhotoWrap.style.display='block';
  updatePhotoAnim();
  state.sourceMode = 'photo';
  updateSourceUI();
  setPhotoStatus(PHOTO_STATUS_DEFAULT, false);
}

function loadPhotoFromFile(f){
  const url = URL.createObjectURL(f);
  const img = new Image();
  img.onload = ()=>{
    state.photoFile = f;
    applyPhotoImage(img, f.name.length>18 ? f.name.slice(0,16)+'…' : f.name);
  };
  img.onerror = ()=>{ setPhotoStatus('Bu dosya görsel olarak açılamadı.', true); };
  img.src = url;
}

function loadPhotoFromUrl(rawUrl){
  const url = (rawUrl||'').trim();
  if(!url){ setPhotoStatus('Önce bir görsel linki yapıştır.', true); return; }
  setPhotoStatus('Görsel yükleniyor…', false);
  const img = new Image();
  img.crossOrigin = 'anonymous';
  img.onload = ()=>{
    state.photoFile = null;
    let shortLabel = url;
    try{ shortLabel = new URL(url).hostname; }catch(e){}
    applyPhotoImage(img, 'Link: '+(shortLabel.length>20 ? shortLabel.slice(0,18)+'…' : shortLabel));
  };
  img.onerror = ()=>{
    setPhotoStatus('Bu link yüklenemedi — site görsele dışarıdan erişimi kısıtlıyor olabilir. Görseli indirip dosya olarak yüklemeyi dene.', true);
  };
  img.src = url;
}

photoInput.addEventListener('change', e=>{
  const f = e.target.files[0];
  if(!f) return;
  loadPhotoFromFile(f);
});

$('photoUrlLoadBtn').addEventListener('click', ()=>{
  loadPhotoFromUrl($('photoUrlInput').value);
});
$('photoUrlInput').addEventListener('keydown', e=>{
