  return 'linear-gradient(0deg, '+hexToRgba(state.c2,strongA)+' 0%, '+hexToRgba(state.c1,baseA)+' 45%, '+hexToRgba(state.c1,midA)+' 68%, rgba(0,0,0,0) 100%)';
