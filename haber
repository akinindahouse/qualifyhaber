function exportReady(){
  return (state.sourceMode==='video' && state.hasVideo) || (state.sourceMode==='photo' && state.hasPhoto);
}

function updateExportButtonState(){
  $('exportVideoBtn').disabled = state.recording || !exportReady();
}

function updateSourceUI(){
  const v = state.sourceMode==='video';
  $('sourceModeVideo').classList.toggle('active', v);
  $('sourceModePhoto').classList.toggle('active', !v);
  $('videoSourceFields').style.display = v ? 'block' : 'none';
  $('photoSourceFields').style.display = v ? 'none' : 'block';
  frameVideo.style.display = (v && state.hasVideo) ? 'block' : 'none';
  frameImage.style.display = (!v && state.hasPhoto) ? 'block' : 'none';
  emptyFrame.style.display = ((v && !state.hasVideo) || (!v && !state.hasPhoto)) ? 'flex' : 'none';
  if(v && state.hasVideo){ frameVideo.play().catch(()=>{}); }
  if(!v){ frameVideo.pause(); }
  updateExportButtonState();
}

$('sourceModeVideo').addEventListener('click', ()=>{ state.sourceMode='video'; updateSourceUI(); });
$('sourceModePhoto').addEventListener('click', ()=>{ state.sourceMode='photo'; updateSourceUI(); });

function hexToRgba(hex, a){
  const h = hex.replace('#','');
  const r = parseInt(h.substring(0,2),16), g = parseInt(h.substring(2,4),16), b = parseInt(h.substring(4,6),16);
  return 'rgba('+r+','+g+','+b+','+a+')';
}

function buildPresetSwatches(){
  const wrap = $('presetSwatches');
  wrap.innerHTML='';
  PRESETS.forEach((p,i)=>{
    const el = document.createElement('div');
    el.className='swatch'+(i===0?' active':'');
    el.style.background = p.style==='radial'
      ? 'radial-gradient(circle at 50% 50%,'+p.c1+','+p.c2+')'
      : 'linear-gradient('+p.angle+'deg,'+p.c1+','+p.c2+')';
    el.title = p.name;
    el.addEventListener('click', ()=>{
      document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('active'));
      el.classList.add('active');
      state.c1=p.c1; state.c2=p.c2; state.gradStyle=p.style; state.angle=p.angle;
      $('color1').value=p.c1; $('color2').value=p.c2; $('gradStyle').value=p.style; $('angle').value=p.angle;
      $('angleOut').textContent=p.angle+'°';
      render();
    });
    wrap.appendChild(el);
  });
}
buildPresetSwatches();

function deselectSwatches(){ document.querySelectorAll('.swatch').forEach(s=>s.classList.remove('active')); }

