<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>QualifyHaber — Reels Stüdyosu</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Archivo+Black&family=Inter:wght@400;500;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
  :root{
    --bg:#0A0C0F;
    --panel:#14171C;
    --panel-2:#191D24;
    --field:#0E1116;
    --border:#262B33;
    --border-soft:#1D2128;
    --text:#F4F5F7;
    --muted:#888F9B;
    --muted-2:#5C636E;
    --accent:#FF3B30;
    --accent-dim:#7A1F1A;
    --accent-2:#FFB020;
    --good:#2BD17E;
    --mono:'Space Mono', monospace;
    --display:'Archivo Black', sans-serif;
    --body:'Inter', sans-serif;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;background:var(--bg);color:var(--text);font-family:var(--body);}
  body{min-height:100vh;}

  ::selection{background:var(--accent);color:#fff;}
  input,select,textarea,button{font-family:var(--body);}

  /* ---------- top bar ---------- */
  .topbar{
    display:flex;align-items:center;justify-content:space-between;
    padding:18px 28px;border-bottom:1px solid var(--border-soft);
    background:linear-gradient(180deg,#0D0F13,#0A0C0F);
  }
  .brand{display:flex;align-items:center;gap:12px;}
  .brand-mark{
    width:34px;height:34px;border-radius:8px;background:var(--accent);
    display:flex;align-items:center;justify-content:center;
    font-family:var(--display);font-size:17px;color:#fff;flex:none;
  }
  .brand-text h1{font-size:15px;margin:0;font-weight:700;letter-spacing:.2px;}
  .brand-text p{
    margin:2px 0 0;font-family:var(--mono);font-size:10px;letter-spacing:1.6px;
    color:var(--muted-2);text-transform:uppercase;
  }
  .topbar-tag{
    font-family:var(--mono);font-size:11px;color:var(--muted);
    border:1px solid var(--border);padding:6px 12px;border-radius:20px;
    letter-spacing:.5px;
  }
  .topbar-tag b{color:var(--accent-2);font-weight:700;}

  /* ---------- workspace ---------- */
  .workspace{
    display:grid;grid-template-columns:380px 1fr;gap:0;
    min-height:calc(100vh - 71px);
  }
  @media (max-width: 920px){
    .workspace{grid-template-columns:1fr;}
  }

  /* ---------- controls ---------- */
  .controls{
    border-right:1px solid var(--border-soft);
    background:var(--panel);
    padding:22px 22px 60px;
    overflow-y:auto;
    max-height:calc(100vh - 71px);
  }
  .section{margin-bottom:28px;}
  .section-head{
    display:flex;align-items:center;gap:8px;margin-bottom:14px;
  }
  .section-num{
    font-family:var(--mono);font-size:11px;color:var(--bg);
    background:var(--accent-2);width:20px;height:20px;border-radius:5px;
    display:flex;align-items:center;justify-content:center;font-weight:700;flex:none;
  }
  .section-head h2{font-size:13px;margin:0;font-weight:700;letter-spacing:.3px;}

  .field{margin-bottom:14px;}
  .field label{
    display:block;font-size:11px;color:var(--muted);margin-bottom:6px;
    font-family:var(--mono);letter-spacing:.4px;text-transform:uppercase;
  }
  .field input[type=text], .field textarea{
    width:100%;background:var(--field);border:1px solid var(--border);
    color:var(--text);padding:9px 11px;border-radius:7px;font-size:13.5px;
    outline:none;resize:none;
  }
  .field input[type=text]:focus, .field textarea:focus{border-color:var(--accent-2);}
  .field textarea{min-height:56px;line-height:1.4;}
  .hint{font-size:11px;color:var(--muted-2);margin-top:5px;line-height:1.5;}

  .filebtn{
    display:flex;align-items:center;justify-content:space-between;gap:10px;
    background:var(--field);border:1px dashed var(--border);border-radius:7px;
    padding:11px 12px;cursor:pointer;font-size:12.5px;color:var(--muted);
  }
  .filebtn:hover{border-color:var(--accent-2);color:var(--text);}
  .filebtn input{display:none;}
  .filebtn .fname{color:var(--good);font-family:var(--mono);font-size:11px;}

  .toggle-row{display:flex;gap:8px;margin-bottom:14px;}
  .toggle-row button{
    flex:1;background:var(--field);border:1px solid var(--border);color:var(--muted);
    padding:9px 10px;border-radius:7px;font-size:12.5px;cursor:pointer;font-weight:600;
  }
  .toggle-row button.active{background:var(--accent);border-color:var(--accent);color:#fff;}

  .swatches{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:14px;}
  .swatch{
    aspect-ratio:1;border-radius:8px;cursor:pointer;border:2px solid transparent;
    position:relative;
  }
  .swatch.active{border-color:#fff;}
  .swatch span{
    position:absolute;bottom:-18px;left:0;right:0;text-align:center;
    font-size:9px;color:var(--muted-2);font-family:var(--mono);
  }

  .row2{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
  .colorpick{display:flex;align-items:center;gap:8px;background:var(--field);border:1px solid var(--border);border-radius:7px;padding:6px 10px;}
  .colorpick input[type=color]{width:26px;height:26px;border:none;background:none;padding:0;cursor:pointer;}
  .colorpick span{font-family:var(--mono);font-size:11px;color:var(--muted);}

  .slider-row{margin-bottom:14px;}
  .slider-row .slabel{display:flex;justify-content:space-between;font-size:11px;color:var(--muted);font-family:var(--mono);margin-bottom:6px;text-transform:uppercase;letter-spacing:.4px;}
  .slider-row .slabel b{color:var(--accent-2);font-weight:700;}
  input[type=range]{
    -webkit-appearance:none;width:100%;height:3px;background:var(--border);
    border-radius:2px;outline:none;
  }
  input[type=range]::-webkit-slider-thumb{
    -webkit-appearance:none;width:14px;height:14px;border-radius:50%;
    background:var(--accent-2);cursor:pointer;border:2px solid var(--bg);
  }

  select{
    width:100%;background:var(--field);border:1px solid var(--border);color:var(--text);
    padding:9px 11px;border-radius:7px;font-size:13px;outline:none;
  }

  .checkrow{display:flex;align-items:center;gap:9px;margin-bottom:10px;cursor:pointer;}
  .checkrow input{width:16px;height:16px;accent-color:var(--accent);cursor:pointer;}
  .checkrow span{font-size:12.5px;color:var(--text);}

  .export-btn{
    width:100%;padding:13px;border-radius:8px;border:none;cursor:pointer;
    font-size:13.5px;font-weight:700;margin-bottom:10px;
    display:flex;align-items:center;justify-content:center;gap:8px;
  }
  .export-btn.primary{background:var(--accent);color:#fff;}
  .export-btn.primary:hover{background:#FF5246;}
  .export-btn.secondary{background:var(--field);border:1px solid var(--border);color:var(--text);}
  .export-btn.secondary:hover{border-color:var(--accent-2);}
  .export-btn:disabled{opacity:.45;cursor:not-allowed;}
  .export-note{
    font-size:11px;color:var(--muted-2);line-height:1.6;background:var(--field);
    border:1px solid var(--border-soft);border-radius:7px;padding:10px 11px;margin-top:8px;
  }
  .export-note b{color:var(--muted);}

  /* ---------- preview stage ---------- */
  .preview-stage{
    display:flex;flex-direction:column;align-items:center;justify-content:flex-start;
    padding:40px 24px 60px;gap:16px;
  }
  .stage-readout{
    font-family:var(--mono);font-size:11px;color:var(--muted-2);
    display:flex;align-items:center;gap:14px;letter-spacing:.4px;
  }
  .rec-dot{width:7px;height:7px;border-radius:50%;background:var(--muted-2);}
  .rec-dot.live{background:var(--accent);animation:blink 1s infinite;}
  @keyframes blink{50%{opacity:.25;}}

  .frame-wrap{
    position:relative;width:min(360px, 80vw);aspect-ratio:9/16;
    background:#000;border-radius:22px;overflow:hidden;
    box-shadow:0 0 0 1px var(--border-soft), 0 30px 70px rgba(0,0,0,.55);
  }
  .frame-media{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;background:#050608;z-index:1;}
  .frame-media.kenburns-anim{animation:kbzoom 9s ease-in-out infinite alternate;}
  @keyframes kbzoom{from{transform:scale(1);}to{transform:scale(1.08);}}
  .frame-overlay{position:absolute;inset:0;mix-blend-mode:normal;pointer-events:none;z-index:3;}

  .frame-brand{
    position:absolute;left:6%;right:18%;display:flex;align-items:center;gap:8px;z-index:4;
  }
  .frame-brand img{height:34px;max-width:100%;object-fit:contain;display:block;}
  .frame-brand .wordmark{
    font-family:var(--display);font-size:19px;line-height:1;letter-spacing:.2px;
    display:flex;gap:0;text-shadow:0 2px 10px rgba(0,0,0,.5);
  }
  .frame-brand .wordmark .w1{color:#fff;}
  .frame-brand .wordmark .w2{color:var(--accent);}

  .frame-textblock{position:absolute;left:6%;right:18%;display:flex;flex-direction:column;gap:10px;z-index:4;}
  .frame-tag{
    align-self:flex-start;font-family:var(--mono);font-size:10.5px;font-weight:700;
    letter-spacing:1.4px;text-transform:uppercase;color:#0A0C0F;background:var(--accent-2);
    padding:5px 11px;border-radius:4px;
  }
  .frame-title{
    font-family:var(--display);color:#fff;font-size:30px;line-height:1.12;
    text-shadow:0 3px 16px rgba(0,0,0,.6);word-break:keep-all;
  }

  .safezone{position:absolute;inset:0;pointer-events:none;opacity:0;transition:opacity .2s;z-index:5;}
  .safezone.show{opacity:1;}
  .sz-band{position:absolute;left:0;right:0;border-color:rgba(255,176,32,.55);}
  .sz-band.top{top:0;height:11.5%;border-bottom:1px dashed rgba(255,176,32,.55);}
  .sz-band.bottom{bottom:0;height:17%;border-top:1px dashed rgba(255,176,32,.55);}
  .sz-side{position:absolute;top:11.5%;bottom:17%;right:0;width:13%;border-left:1px dashed rgba(255,176,32,.4);}
  .sz-label{
    position:absolute;font-family:var(--mono);font-size:8px;color:var(--accent-2);
    letter-spacing:.5px;text-transform:uppercase;background:rgba(10,12,15,.7);
    padding:2px 5px;border-radius:3px;
  }

  .corner{position:absolute;width:22px;height:22px;border-color:rgba(255,255,255,.55);z-index:6;}
  .corner.tl{top:10px;left:10px;border-top:2px solid;border-left:2px solid;border-radius:4px 0 0 0;}
  .corner.tr{top:10px;right:10px;border-top:2px solid;border-right:2px solid;border-radius:0 4px 0 0;}
  .corner.bl{bottom:10px;left:10px;border-bottom:2px solid;border-left:2px solid;border-radius:0 0 0 4px;}
  .corner.br{bottom:10px;right:10px;border-bottom:2px solid;border-right:2px solid;border-radius:0 0 4px 0;}

  .empty-frame{
    position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
    flex-direction:column;gap:10px;color:var(--muted-2);text-align:center;padding:0 30px;z-index:2;
  }
  .empty-frame svg{opacity:.4;}
  .empty-frame p{font-size:11.5px;line-height:1.5;margin:0;}

  .stage-caption{
    font-family:var(--mono);font-size:11px;color:var(--muted-2);text-align:center;max-width:340px;line-height:1.6;
  }
</style>
</head>
<body>

<div class="topbar">
  <div class="brand">
    <div class="brand-mark">Q</div>
    <div class="brand-text">
      <h1>QualifyHaber</h1>
      <p>Reels Şablon Stüdyosu</p>
    </div>
  </div>
  <div class="topbar-tag">9:16 · <b>Instagram Safe Zone</b> uyumlu</div>
</div>

<div class="workspace">

  <aside class="controls">

    <div class="section">
      <div class="section-head"><div class="section-num">1</div><h2>Kaynak</h2></div>

      <div class="toggle-row">
        <button class="active" id="sourceModeVideo">Video</button>
        <button id="sourceModePhoto">Fotoğraf</button>
      </div>

      <div id="videoSourceFields">
        <div class="field">
          <label>Arka plan videosu</label>
          <label class="filebtn">
            <span id="videoFileLabel">Video seç (mp4, mov…)</span>
            <span class="fname" id="videoFileName"></span>
            <input type="file" id="videoInput" accept="video/*">
          </label>
          <p class="hint">Video, kareyi 9:16 oranında otomatik kırpıp kaplar.</p>
        </div>
        <div class="field" id="clearVideoWrap" style="display:none;">
          <button class="export-btn secondary" id="clearVideoBtn" style="margin:0;">Videoyu kaldır</button>
        </div>
      </div>

      <div id="photoSourceFields" style="display:none;">
        <div class="field">
          <label>Haber fotoğrafı</label>
          <label class="filebtn">
            <span id="photoFileLabel">Fotoğraf seç (jpg, png…)</span>
            <span class="fname" id="photoFileName"></span>
            <input type="file" id="photoInput" accept="image/*">
          </label>
          <p class="hint">Videon yoksa bu fotoğrafla da gerçek bir Reels videosu üretilir; fotoğraf kareyi aynı şekilde kaplar ve güvenli alana göre otomatik hizalanır.</p>
        </div>
        <div class="field" id="clearPhotoWrap" style="display:none;">
          <button class="export-btn secondary" id="clearPhotoBtn" style="margin:0;">Fotoğrafı kaldır</button>
        </div>
        <div class="slider-row">
          <div class="slabel"><span>Reels süresi</span><b id="photoDurOut">6 sn</b></div>
          <input type="range" id="photoDuration" min="3" max="15" value="6">
        </div>
        <label class="checkrow">
          <input type="checkbox" id="kenBurnsToggle" checked>
          <span>Hafif yakınlaşma efekti (sabit fotoğrafı daha canlı gösterir)</span>
        </label>
      </div>
    </div>

    <div class="section">
      <div class="section-head"><div class="section-num">2</div><h2>Marka</h2></div>

      <label class="checkrow">
        <input type="checkbox" id="brandVisibleToggle" checked>
        <span>Marka öğesini göster</span>
      </label>

      <div id="brandFieldsWrap">
        <div class="toggle-row">
          <button class="active" id="brandModeText">Yazı</button>
          <button id="brandModeLogo">Kendi logom</button>
        </div>

        <div id="brandTextFields">
          <div class="field">
            <label>Marka yazısı</label>
            <input type="text" id="brandTextInput" maxlength="28" value="QualifyHaber">
          </div>
          <div class="field">
            <label>Vurgulanacak kısım (opsiyonel)</label>
            <input type="text" id="brandHighlightInput" maxlength="20" value="Haber">
            <p class="hint">Yazı içinde bu kısmı bulup vurgu rengiyle gösteririz. Boş bırakırsan ya da yazıyla eşleşmezse tüm yazı beyaz görünür.</p>
          </div>
        </div>

        <div class="field" id="logoFieldWrap" style="display:none;">
          <label class="filebtn">
            <span id="logoFileLabel">Logo yükle (png, şeffaf)</span>
            <span class="fname" id="logoFileName"></span>
            <input type="file" id="logoInput" accept="image/*">
          </label>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="section-head"><div class="section-num">3</div><h2>İçerik</h2></div>
      <div class="field">
        <label>Konu / kategori etiketi</label>
        <input type="text" id="tagInput" maxlength="22" value="GÜNDEM">
      </div>
      <div class="field">
        <label>Haber başlığı</label>
        <textarea id="titleInput" maxlength="110">Başlığı buraya yaz, otomatik satır kırılır</textarea>
        <p class="hint" id="titleCount">0/110</p>
      </div>
    </div>

    <div class="section">
      <div class="section-head"><div class="section-num">4</div><h2>Gradyan</h2></div>
      <div class="swatches" id="presetSwatches"></div>
      <div class="row2" style="margin-top:22px;">
        <div class="colorpick"><input type="color" id="color1" value="#FF2D2D"><span>Renk 1</span></div>
        <div class="colorpick"><input type="color" id="color2" value="#1A0000"><span>Renk 2</span></div>
      </div>
      <div class="field" style="margin-top:12px;">
        <select id="gradStyle">
          <option value="linear">Doğrusal geçiş</option>
          <option value="radial">Dairesel geçiş</option>
        </select>
      </div>
      <div class="slider-row" id="angleRow">
        <div class="slabel"><span>Açı</span><b id="angleOut">160°</b></div>
        <input type="range" id="angle" min="0" max="360" value="160">
      </div>
      <div class="slider-row">
        <div class="slabel"><span>Gradyan yoğunluğu</span><b id="opacityOut">%55</b></div>
        <input type="range" id="opacity" min="0" max="100" value="55">
      </div>
    </div>

    <div class="section">
      <div class="section-head"><div class="section-num">5</div><h2>Çerçeve</h2></div>
      <label class="checkrow">
        <input type="checkbox" id="safezoneToggle" checked>
        <span>Instagram safe zone kılavuzunu göster (sadece önizleme, dışa aktarmaya dahil olmaz)</span>
      </label>
    </div>

    <div class="section">
      <div class="section-head"><div class="section-num">6</div><h2>Dışa aktar</h2></div>
      <div class="field">
        <label>Çözünürlük</label>
        <select id="exportRes">
          <option value="1080x1920">1080×1920 — önerilen (Instagram standardı)</option>
          <option value="720x1280">720×1280 — daha hızlı, daha küçük dosya</option>
        </select>
      </div>
      <button class="export-btn secondary" id="exportPngBtn">Kapak görseli indir (PNG)</button>
      <button class="export-btn primary" id="exportVideoBtn" disabled>Reels videosu indir (MP4)</button>
      <div class="export-note">
        <b>Not:</b> Çıktı doğrudan <b>.mp4</b> olarak iner, telefona aktarıp direkt Instagram'a yükleyebilirsin — ekstra dönüştürme gerekmez. İlk kullanımda tarayıcı, dönüştürme motorunu bir kerelik indirir (~25MB, birkaç saniye-yarım dakika sürebilir, internet gerekir); sonraki tüm aktarımlar tarayıcı önbelleğinden çalışıp çok daha hızlı olur. Safari kullanıyorsan bu adım atlanır, mp4 anında üretilir.
      </div>
    </div>

  </aside>

  <main class="preview-stage">
    <div class="stage-readout">
      <span class="rec-dot" id="recDot"></span>
      <span id="recLabel">ÖNİZLEME</span>
      <span id="timecode">00:00</span>
    </div>

    <div class="frame-wrap" id="frameWrap">
      <video class="frame-media" id="frameVideo" muted loop playsinline></video>
      <img class="frame-media" id="frameImage" style="display:none;">
      <div class="empty-frame" id="emptyFrame">
        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="4" width="14" height="13" rx="2"/><path d="M16 9l5-3v12l-5-3"/></svg>
        <p>Henüz video ya da fotoğraf yüklenmedi.<br>Şu an sade gradyan kapak görünüyor.</p>
      </div>
      <div class="frame-overlay" id="frameOverlay"></div>

      <div class="frame-brand" id="frameBrand" style="top:8%;">
        <div class="wordmark" id="brandWordmark"><span class="w1" id="wmPre">Qualify</span><span class="w2" id="wmHi">Haber</span><span class="w1" id="wmPost"></span></div>
        <img id="brandLogoImg" style="display:none;">
      </div>

      <div class="frame-textblock" id="frameTextblock" style="bottom:18%;">
        <div class="frame-tag" id="frameTag">GÜNDEM</div>
        <div class="frame-title" id="frameTitle">Başlığı buraya yaz, otomatik satır kırılır</div>
      </div>

      <div class="safezone show" id="safezone">
        <div class="sz-band top"><span class="sz-label" style="bottom:-16px;left:6%;">üst güvenli alan</span></div>
        <div class="sz-band bottom"><span class="sz-label" style="top:-16px;left:6%;">alt güvenli alan · IG arayüzü</span></div>
        <div class="sz-side"><span class="sz-label" style="writing-mode:vertical-rl;top:46%;right:4px;">ikon kolonu</span></div>
      </div>

      <div class="corner tl"></div>
      <div class="corner tr"></div>
      <div class="corner bl"></div>
      <div class="corner br"></div>
    </div>

    <p class="stage-caption">Çerçeve, gerçek Reels oynatıcısının üst profil alanını, alt başlık/buton şeridini ve sağdaki beğeni-yorum ikon kolonunu temsil eder. Metinleri bu kılavuzların dışında tutarsan Instagram arayüzü hiçbir şeyi kapatmaz.</p>
  </main>

</div>

<canvas id="exportCanvas" width="1080" height="1920" style="display:none;"></canvas>

<script src="https://unpkg.com/@ffmpeg/ffmpeg@0.11.6/dist/ffmpeg.min.js"></script>
<script>
const PRESETS = [
  {name:'Son Dakika', c1:'#FF2D2D', c2:'#1A0000', angle:160, style:'linear'},
  {name:'Gece Bülteni', c1:'#5A3CFF', c2:'#0A0A1A', angle:160, style:'linear'},
  {name:'Ekonomi', c1:'#FFB020', c2:'#1A1200', angle:160, style:'linear'},
  {name:'Spor', c1:'#1FD15A', c2:'#001A08', angle:160, style:'linear'},
  {name:'Sade Kontrast', c1:'#000000', c2:'#000000', angle:180, style:'radial'}
];

const state = {
  sourceMode:'video',
  hasVideo:false,
  videoFile:null,
  hasPhoto:false,
  photoFile:null,
  photoImg:null,
  photoDurationSec:6,
  kenBurns:true,
  brandVisible:true,
  brandMode:'text',
  brandText:'QualifyHaber',
  brandHighlight:'Haber',
