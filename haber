$('exportVideoBtn').addEventListener('click', async ()=>{
  if(state.recording || !exportReady()) return;
  await document.fonts.ready;
  setCanvasSizeFromExportRes();

  const stream = exportCanvas.captureStream(30);
  if(state.sourceMode==='video'){
    try{
      const vStream = frameVideo.captureStream ? frameVideo.captureStream() : (frameVideo.mozCaptureStream ? frameVideo.mozCaptureStream() : null);
      if(vStream){ vStream.getAudioTracks().forEach(t=>stream.addTrack(t)); }
    }catch(err){}
  }

  let nativeMp4 = false;
  try{ nativeMp4 = MediaRecorder.isTypeSupported('video/mp4'); }catch(e){}

  const mimeType = nativeMp4 ? 'video/mp4' : (
    MediaRecorder.isTypeSupported('video/webm;codecs=vp9,opus') ? 'video/webm;codecs=vp9,opus' :
    (MediaRecorder.isTypeSupported('video/webm;codecs=vp8,opus') ? 'video/webm;codecs=vp8,opus' : 'video/webm')
  );

  let recorder;
  try{
    recorder = new MediaRecorder(stream, {mimeType, videoBitsPerSecond:8000000});
  }catch(err){
    alert('Tarayıcın video kaydını desteklemiyor. Güncel bir Chrome ile dene.');
    return;
  }
  const chunks = [];
  recorder.ondataavailable = e=>{ if(e.data && e.data.size) chunks.push(e.data); };
  recorder.onstop = async ()=>{
    const rawBlob = new Blob(chunks, {type: nativeMp4 ? 'video/mp4' : 'video/webm'});

    if(nativeMp4){
      downloadBlob(rawBlob, FORMAT_CONFIG[state.format].filenamePrefix+'.mp4');
      setRecordingUI(false);
      return;
    }

    try{
      const [w,h] = state.exportRes.split('x').map(Number);
      const mp4Blob = await convertToMp4(rawBlob, w, h, setStage, setStageProgress);
      downloadBlob(mp4Blob, FORMAT_CONFIG[state.format].filenamePrefix+'.mp4');
    }catch(err){
      console.error(err);
      alert('MP4\u2019e dönüştürme başarısız oldu, WEBM olarak indirildi. Telefonda CapCut veya VLC ile mp4\u2019e çevirebilirsin.');
      downloadBlob(rawBlob, FORMAT_CONFIG[state.format].filenamePrefix+'.webm');
    } finally {
      setRecordingUI(false);
    }
  };

  let raf, recStartTs;
  function loop(){
    const elapsed = performance.now() - recStartTs;
    drawFrame(elapsed);
    raf = requestAnimationFrame(loop);
  }

  setRecordingUI(true);

  let durMs;
  if(state.sourceMode==='video'){
    frameVideo.currentTime = 0;
    try{ await frameVideo.play(); }catch(err){}
    durMs = (frameVideo.duration && isFinite(frameVideo.duration)) ? frameVideo.duration*1000 : 8000;
  } else {
    durMs = state.photoDurationSec*1000;
  }

  recStartTs = performance.now();
  recorder.start();
  loop();

  setTimeout(()=>{
    cancelAnimationFrame(raf);
    if(recorder.state !== 'inactive') recorder.stop();
  }, durMs);
});

/* ---------- keep the on-screen preview title in sync with the export's auto-fit sizing ---------- */
const frameWrapEl = $('frameWrap');
const frameTitleEl = $('frameTitle');

function updatePreviewTitleSize(){
  const wrapWidth = frameWrapEl.clientWidth;
  if(!wrapWidth) return;
  const scale = wrapWidth / CW;

  const rightLimit = CW - CW*(SAFE.side + SAFE.rightIcons);
  const leftX = CW*SAFE.side;
  const maxWidth = rightLimit - leftX;
  const bottomLimit = (CH - CH*SAFE.bottom) - getHintReserveH();
  const topLimit = CH * 0.30;
  const tagH = 58, gap = 22;
  const availableForLines = (bottomLimit - topLimit) - tagH - gap;

  const {fontSize, lineHeight} = fitTitleLines(state.title, maxWidth, availableForLines, state.titleMaxFont||66, 32, 1.15);
  frameTitleEl.style.fontSize = Math.round(fontSize*scale)+'px';
  frameTitleEl.style.lineHeight = Math.round(lineHeight*scale)+'px';
}

/* Canvas measureText silently falls back to a generic font while the Archivo Black
   webfont is still downloading, which under-estimates glyph widths and can make the
   auto-fit think a long title fits when it doesn't. Re-run the fit once the real
   font is confirmed loaded so sizing/wrapping is always accurate. */
document.fonts.ready.then(()=>{ updatePreviewTitleSize(); });

new ResizeObserver(()=>updatePreviewTitleSize()).observe(frameWrapEl);



